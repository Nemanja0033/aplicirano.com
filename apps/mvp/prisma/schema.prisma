generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id        String   @id @default(uuid())
  title     String
  appliedAt DateTime @default(now())
  updatedAt DateTime @default(now())
  status    String   @default("APPLIED")
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  profileId String?
  resumeId  String?
  resume    resume?  @relation(fields: [resumeId], references: [id])
  profile   Profile? @relation(fields: [profileId], references: [id])
  position  String?
  jobUrl    String?
  salarly   Int?
  location  String?
  notes     String?
}

model resume {
  id            String   @id @default(uuid())
  title         String
  resumeUrl     String
  resumeContent String?
  fileSize      String
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  profileId     String?
  profile       Profile? @relation(fields: [profileId], references: [id])
  jobs          Job[]
  createdAt     DateTime @default(now())
}

model User {
  id                  String    @id @default(uuid())
  firebaseUid         String    @unique
  email               String    @unique
  username            String
  avatarUrl           String?
  apiCredits          Int       @default(3)
  jobsLimit           Int       @default(25)
  profileLimit        Int       @default(3)
  resumeLimit         Int       @default(3)
  isProUSer           Boolean   @default(false)
  isUserAcceptedTerms Boolean   @default(false)
  jobs                Job[]
  profiles            Profile[] // novi odnos
  resumes             resume[]
}

model Profile {
  id        String   @id @default(uuid())
  name      String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  resumes   resume[]
  jobs      Job[]
  createdAt DateTime @default(now())
}

model WaitlistEmail {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  email     String   @unique
}

enum JobStatus {
  APPLIED
  REJECTED
  INTERVIEW
}

model BugReport {
  id             String   @id @default(ulid())
  type           String
  bugDescription String
  reportedBy     String
  reportedAt     DateTime @default(now())
}
